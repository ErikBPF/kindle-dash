# Copy to renderer/.env and fill in. Everything is optional except resolution —
# widgets whose config is blank just render a placeholder. See CONFIGURATION.md.

# --- display ---------------------------------------------------------------
# Match your Kindle's screen (landscape: width >= height; the renderer rotates
# for the device). Paperwhite 2 = 1024x758; PW3+/Oasis = 1448x1072.
KINDLE_W=1024
KINDLE_H=758
TZ=America/Sao_Paulo

# Visual options — all server-side, so the device just opens a bare /dash.png.
DASH_ROTATE=0          # 0/90/180/270; 90 fills a portrait panel mounted sideways
DASH_DARK=0            # 1 = light-on-black (e-ink dark mode)
DASH_WIDGETS=clock,weather,forecast,agenda,sunmoon,usage   # which panels, in order

# Host port the renderer is published on (compose). The Kindle fetches this.
PORT=8810

# --- Home Assistant (optional: weather / forecast / sun / agenda) ----------
# Long-lived token: HA -> Profile -> Security -> Long-lived access tokens.
HA_BASE_URL=
HA_TOKEN=
HA_WEATHER_ENTITY=        # e.g. weather.home  (also drives the forecast strip)
HA_CALENDAR_ENTITY=       # e.g. calendar.personal  (blank = hide agenda)
HA_SUN_ENTITY=sun.sun     # sunrise/sunset; moon phase is computed locally
FORECAST_DAYS=3
DASH_MAX_EVENTS=4

# --- Claude usage (optional: Session / Week / Sonnet bars) -----------------
# Seed from a DEDICATED Claude login, NOT a workstation's (see SECURITY.md):
#   mkdir -p ~/dash-claude-auth
#   env CLAUDE_CONFIG_DIR=$HOME/dash-claude-auth claude   # then /login, /exit
#   jq -r .claudeAiOauth.refreshToken ~/dash-claude-auth/.credentials.json
CLAUDE_REFRESH_TOKEN=
CLAUDE_POLL_MIN=15
# Defaults below are correct as of writing; override only if the (undocumented)
# endpoints move. See SECURITY.md.
# CLAUDE_TOKEN_URL=https://api.anthropic.com/v1/oauth/token
# CLAUDE_USAGE_URL=https://api.anthropic.com/api/oauth/usage
